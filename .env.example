# ── Backend ──
PORT=3457
NODE_ENV=production
LOG_LEVEL=info

# Database — these match the compose service name
DB_HOST=postgres
DB_PORT=5432
DB_NAME=presupuesto
DB_USER=budget
DB_PASSWORD=budget123

# JWT — CHANGE THESE IN PRODUCTION
JWT_ACCESS_SECRET=changeme-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=changeme-refresh-secret-min-32-chars!

# CORS — frontend URL
CORS_ORIGINS=http://localhost:3456

# Docker ports (optional, defaults: frontend=3456, backend=3457)
FRONTEND_PORT=3456
BACKEND_PORT=3457
