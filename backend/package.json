{
  "name": "budget-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "mikro-orm": {
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "tsx src/scripts/run-migration.ts",
    "migrate:prod": "node dist/scripts/run-migration.js",
    "migrate:down": "tsx node_modules/.bin/mikro-orm migration:down",
    "migrate:list": "tsx node_modules/.bin/mikro-orm migration:list",
    "migrate:create": "tsx node_modules/.bin/mikro-orm migration:create",
    "seed": "tsx src/seed.ts",
    "seed:prod": "node dist/seed.js"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "@mikro-orm/reflection": "^6.6.15",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.15",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
